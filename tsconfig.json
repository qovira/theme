{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src", "tsup.config.ts", "vitest.config.ts"]
}
