{
  "name": "@qovira/theme",
  "version": "1.1.0",
  "description": "Qovira's visual foundation — Tailwind v4 tokens, self-hosted fonts, and a framework-agnostic theming runtime.",
  "keywords": [
    "qovira",
    "design-tokens",
    "tailwindcss",
    "theme",
    "css"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qovira/theme.git"
  },
  "homepage": "https://github.com/qovira/theme#readme",
  "bugs": "https://github.com/qovira/theme/issues",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24"
  },
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./dist/theme.css",
    "./fonts": "./dist/fonts.css",
    "./runtime": "./dist/runtime.js",
    "./boot": "./dist/boot.js"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/postcss": "^4.3.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.9.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
